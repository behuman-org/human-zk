# Funding API (CAPA 3) — solo modo dev soportado por ahora.
# El modo "real" (DeFindex + Trustless Work + campaign_controller) está bloqueado al iniciar.
# Ver docs/funding.md

FUNDING_PROVIDER=dev
FUNDING_API_PORT=8789
ASSET=XLM

# Opcional: persistencia durable (Render/prod). Sin credenciales → archivo local .funding-store.json
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# FUNDING_STORE=

# CORS (default *)
# CORS_ORIGIN=http://localhost:5173

# Providers externos — ignorados mientras FUNDING_PROVIDER=dev (único modo activo)
# DEFINDEX_API_URL=https://api.defindex.io
# DEFINDEX_API_KEY=
# DEFINDEX_NETWORK=testnet
# TRUSTLESS_WORK_API_URL=https://api.trustlesswork.com
# TRUSTLESS_WORK_API_KEY=
