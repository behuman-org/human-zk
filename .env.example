# Copiá este archivo a .env y completá los valores. NO commitees .env.

# --- Stellar / Soroban ---
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
# Identidad de despliegue (creada con `stellar keys generate`)
STELLAR_SOURCE_ACCOUNT=
# ID del contrato verificador una vez desplegado
KYC_VERIFIER_CONTRACT_ID=

# --- Issuer mock ---
# Clave del issuer que firma credenciales de prueba (mock — no usar en prod)
ISSUER_SIGNING_KEY=

# --- Gate de verificación (matcher DNI + selfie, Capa 1) ---
# Provider activo: "testnet" (face match local) o "renaper" (stub, prod futura)
IDENTITY_PROVIDER=testnet
# Umbral de DISTANCIA EUCLIDIANA para el face match 1:1 de face-api (estándar 0.6;
# MENOR distancia = más parecidos). Match si distancia <= umbral. CALIBRAR con caras
# reales. (Nota: el coseno NO discrimina descriptores de face-api; se usa distancia.)
MATCH_THRESHOLD=0.6
# Puerto del servicio matcher/issuer (backend)
MATCHER_PORT=8787
# URL del backend que consume el frontend
MATCHER_URL=http://localhost:8787
# Carpeta con los pesos de los modelos de face-api (gitignored; ver matcher/README)
FACE_MODELS_PATH=identity/issuer/matcher/models
# Validación de documento (OCR): mínimos para aceptar la imagen como una identificación.
DOC_MIN_KEYWORDS=2
DOC_MIN_TOKENS=15
# Origen permitido para CORS desde el frontend (default: * para desarrollo)
CORS_ORIGIN=*
# Pepper global para el de-dup anti-Sybil: se guarda SOLO sha256(docId+pepper),
# nunca el número de documento. Cambiar por un valor secreto en cada entorno.
DEDUP_PEPPER=cambia-esto-por-un-secreto

# --- Plataforma (CAPA 2) ---
PLATFORM_API_PORT=8788
# Contrato opinion_board desplegado (CAPA 2)
VITE_OPINION_BOARD_CONTRACT_ID=
VITE_PLATFORM_API_URL=http://localhost:8788
# Friendbot para fondear cuentas efímeras (fee payer != address del KYC)
VITE_FRIENDBOT_URL=https://friendbot.stellar.org

# --- Frontend (web/) extra ---
VITE_MATCHER_URL=http://localhost:8787

# --- Frontend (web/) ---
# Las variables expuestas al cliente deben empezar con VITE_
VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
VITE_KYC_VERIFIER_CONTRACT_ID=
