# Copiá este archivo a .env y completá los valores. NO commitees .env.

# --- Stellar / Soroban ---
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
# Identidad de despliegue (creada con `stellar keys generate`)
STELLAR_SOURCE_ACCOUNT=
# ID del contrato verificador una vez desplegado
KYC_VERIFIER_CONTRACT_ID=

# --- Issuer mock (matcher) ---
# Atestación Merkle-only (Poseidon) — NO hay firma EdDSA ni ISSUER_SIGNING_KEY.

# --- Gate de verificación (matcher DNI + selfie, Capa 1) ---
# Provider: testnet (face match local) | dev (solo dev/test, BLOQUEADO en prod) | renaper (stub)
IDENTITY_PROVIDER=testnet
# Umbral de DISTANCIA EUCLIDIANA para el face match 1:1 de face-api (estándar 0.6;
# MENOR distancia = más parecidos). Match si distancia <= umbral. CALIBRAR con caras
# reales. (Nota: el coseno NO discrimina descriptores de face-api; se usa distancia.)
MATCH_THRESHOLD=0.6
# Puerto del servicio matcher/issuer (backend)
MATCHER_PORT=8787
# URL del backend que consume el frontend
MATCHER_URL=http://localhost:8787
# Carpeta con los pesos de los modelos de face-api (gitignored; ver matcher/README)
FACE_MODELS_PATH=identity/issuer/matcher/models
# Validación de documento (OCR): mínimos para aceptar la imagen como una identificación.
DOC_MIN_KEYWORDS=2
DOC_MIN_TOKENS=15
# Origen permitido para CORS desde el frontend (default dev: localhost Vite; NO * en prod)
CORS_ORIGIN=http://localhost:5173
# Pepper global para de-dup anti-Sybil (OBLIGATORIO en prod; fail-fast si falta)
DEDUP_PEPPER=cambia-esto-por-un-secreto
# Cotejo datos↔OCR: true por defecto (mismatch fuerte bloquea)
STRICT_DATA_CHECK=true
# Rate limiting por IP (ventana deslizante en memoria)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_ENROLL_MAX=10
RATE_LIMIT_VERIFY_MAX=20
# TTL sesión de enroll tras /verify-data (ms)
ENROLL_SESSION_TTL_MS=1800000
# Persistencia durable del issuer (opcional; recomendado en prod/PaaS)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Plataforma (CAPA 2) ---
PLATFORM_API_PORT=8788
# Contrato opinion_board desplegado (CAPA 2) — ver también bloque VITE_* abajo
# VITE_OPINION_BOARD_CONTRACT_ID=
# Friendbot para fondear cuentas efímeras (fee payer != address del KYC)
# VITE_FRIENDBOT_URL=https://friendbot.stellar.org
# SECURITY · API off-chain: sesión HMAC (POST mutantes) y moderación humana
SESSION_SECRET=
MODERATION_SECRET=
# Curaduría Nivel 1 (Groq). Sin clave la API escala todo (fail-safe, no publica sin filtro)
GROQ_API_KEY=
# CURATION_MODEL=openai/gpt-oss-20b

# --- Funding ZK (CAPA 3 · DeFindex + Trustless Work) ---
# Activo de la campaña: XLM (testnet, nativo) o USDC (prod). Abstraído por config.
ASSET=XLM
# Provider de las integraciones: "dev" (único operativo) | "real" (BLOQUEADO al iniciar la API)
FUNDING_PROVIDER=dev
FUNDING_API_PORT=8789
# DeFindex (yield en Blend) — https://docs.defindex.io  (auth: Bearer; red por ?network=)
DEFINDEX_API_URL=https://api.defindex.io
DEFINDEX_API_KEY=
# Red y vault. Vault XLM oficial de testnet: CCLV4H7WTLJQ7ATLHBBQV2WW3OINF3FOY5XZ7VPHZO7NH3D2ZS4GFSF6
DEFINDEX_NETWORK=testnet
DEFINDEX_VAULT=
# Trustless Work (escrow/release) — auth header x-api-key. Host testnet/dev:
# https://dev.api.trustlesswork.com  (prod = https://api.trustlesswork.com)
TRUSTLESS_WORK_API_URL=https://dev.api.trustlesswork.com
TRUSTLESS_WORK_API_KEY=
# TW es escrow de stablecoin: trustline = issuer clásico + símbolo. USDC testnet:
TW_TRUSTLINE_ADDRESS=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
TW_TRUSTLINE_SYMBOL=USDC
# Address del validador neutral (árbitro) por defecto en testnet
FUNDING_NEUTRAL_ADDRESS=
# Contrato no-custodial desplegado (testnet). Modelo: una instancia por campaña.
FUNDING_CONTROLLER_CONTRACT_ID=
# SAC del activo en testnet (XLM nativo): CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
FUNDING_ASSET_SAC=

# --- Frontend (web/) ---
# Las variables expuestas al cliente deben empezar con VITE_
# En producción (Vercel) son OBLIGATORIAS — el build falla si faltan URLs críticas.
VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
VITE_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
VITE_KYC_VERIFIER_CONTRACT_ID=
VITE_OPINION_BOARD_CONTRACT_ID=
VITE_MATCHER_URL=http://localhost:8787
VITE_PLATFORM_API_URL=http://localhost:8788
VITE_FUNDING_API_URL=http://localhost:8789
VITE_FRIENDBOT_URL=https://friendbot.stellar.org

# --- Pollar (onboarding fácil: crear wallet con email) — CAPA 1 ---
# Pollar SOLO crea la wallet (custodial); NUNCA firma ni toca el anonimato ZK.
# Key de testnet (prefijo pub_testnet_). Vacío = opción de email oculta.
VITE_POLLAR_PUBLISHABLE_KEY=
