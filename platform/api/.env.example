# Copiá a .env en la raíz del monorepo (dotenv carga ../../../.env desde server.ts).

# Puerto local (Render usa $PORT)
PLATFORM_API_PORT=8788

# Store local (fallback si no hay Upstash)
# PLATFORM_STORE=platform/api/.platform-store.json

# Persistencia durable (opcional; recomendado en prod)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# CORS
CORS_ORIGIN=*

# SECURITY: sesión HMAC para POST mutantes (obligatorio en producción)
SESSION_SECRET=cambia-esto-por-un-secreto-largo

# SECURITY: acceso a cola/resolución de moderación (obligatorio en producción)
MODERATION_SECRET=cambia-esto-por-otro-secreto

# Curaduría Nivel 1 (Groq). Sin clave → fail-safe escalated (no publica sin filtro)
GROQ_API_KEY=
# CURATION_MODEL=openai/gpt-oss-20b

# Cola de moderación humana (opcional; default local en curation/)
# MODERATION_QUEUE=platform/curation/.moderation-queue.json
