# Issuer / Matcher — variables de entorno
# Copiá a .env en la raíz del monorepo o exportá antes de `npm run serve -w @behuman/issuer`.

# --- Obligatorio en producción ---
# Pepper para de-dup anti-Sybil: sha256(docId + DEDUP_PEPPER). Sin esto, el hash es precomputable.
DEDUP_PEPPER=cambia-esto-por-un-secreto-largo

# --- Provider del gate ---
# testnet = face match local | dev = aprueba todo (SOLO dev/test) | renaper = stub prod
IDENTITY_PROVIDER=testnet

# --- Seguridad HTTP ---
# Origen permitido para CORS. Default restrictivo: localhost Vite. NO usar * en prod.
CORS_ORIGIN=http://localhost:5173
# Rate limiting (por IP, ventana deslizante en memoria)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_ENROLL_MAX=10
RATE_LIMIT_VERIFY_MAX=20

# --- Cotejo datos↔OCR ---
# true por defecto (cualquier mismatch bloquea). Modo blando: STRICT_DATA_CHECK=false
# STRICT_DATA_CHECK=false

# --- Sesión de enroll ---
# TTL de la sesión abierta tras /verify-data exitoso (ms). /enroll la consume.
ENROLL_SESSION_TTL_MS=1800000

# --- Persistencia del issuer ---
# Archivo local (default). En PaaS con disco efímero se pierde al reiniciar.
# ISSUER_STATE=./.issuer-state.json
# Persistencia durable opcional (Upstash Redis REST):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Matcher ---
MATCHER_PORT=8787
MATCH_THRESHOLD=0.6
FACE_MODELS_PATH=identity/issuer/matcher/models
OCR_ENABLED=true
OCR_MAX_DIM=2000
DOC_MIN_KEYWORDS=2
DOC_MIN_TOKENS=15
